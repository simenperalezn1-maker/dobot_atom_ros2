
#include "imu_state.idl"
#include "motor_state.idl"
#include "bms_state.idl"

module dobot_atom{
    module msg{
        module dds_{
            @extensibility(FINAL)
            struct LowState_ {
                uint16 algs_mode;          /*对应算法状态机*/
                IMUState_ imu_state;
                MotorState_ motor_state[30];
                BmsState_ bms_state;
                octet wireless_remote[40];
                uint32 reserve;               /*越疆保留*/
            };
        };
    };
};



